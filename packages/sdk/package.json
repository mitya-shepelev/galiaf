{
  "name": "@galiaf/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./web-auth": {
      "types": "./src/web-auth.ts",
      "default": "./dist/web-auth.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node -e \"console.log('No tests for @galiaf/sdk yet')\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@galiaf/types": "workspace:*"
  }
}
