GHCR_NAMESPACE=your-github-org-or-user
IMAGE_TAG=latest
DEPLOY_WEBHOOK_TOKEN=change-me
GALIAF_PUBLIC_SITE_URL=https://www.example.com
GALIAF_ADMIN_PORTAL_URL=https://admin.example.com
GALIAF_MANAGER_CABINET_URL=https://manager.example.com
GALIAF_EMPLOYEE_CABINET_URL=https://employee.example.com

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=galiaf
DATABASE_USER=galiaf
DATABASE_PASSWORD=change-me

CHAT_DATABASE_HOST=postgres
CHAT_DATABASE_PORT=5432
CHAT_DATABASE_NAME=galiaf_chat
CHAT_DATABASE_ADMIN_NAME=postgres
CHAT_DATABASE_USER=galiaf
CHAT_DATABASE_PASSWORD=change-me

REDIS_URL=redis://redis:6379
POSTGRES_DB=galiaf
POSTGRES_USER=galiaf
POSTGRES_PASSWORD=change-me
AUTH_MODE=oidc
AUTH_DEV_BYPASS_ENABLED=false
AUTH_ISSUER_URL=https://auth.example.com/realms/galiaf
AUTH_AUDIENCE=galiaf-core-api
AUTH_JWKS_URI=
AUTH_ALLOWED_CORS_ORIGINS=https://admin.example.com,https://manager.example.com,https://employee.example.com,https://app.example.com
OBSERVABILITY_JOURNAL_DIR=/var/log/journal
OBSERVABILITY_RUN_JOURNAL_DIR=/run/log/journal
