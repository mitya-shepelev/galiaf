{
  "realm": "galiaf",
  "enabled": true,
  "displayName": "Galiaf",
  "sslRequired": "external",
  "registrationAllowed": false,
  "registrationEmailAsUsername": false,
  "rememberMe": true,
  "verifyEmail": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "platform_admin",
        "description": "Global platform administrator"
      }
    ]
  },
  "clientScopes": [
    {
      "name": "galiaf-core-api-audience",
      "description": "Inject galiaf-core-api into access token audience",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "galiaf-core-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "galiaf-core-api",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "galiaf-tenant-context",
      "description": "Baseline tenant context claims for core-api fallback mapping",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "active_tenant",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "active_tenant",
            "claim.name": "active_tenant",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "tenant_roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenant_roles",
            "claim.name": "tenant_roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "galiaf-core-api",
      "name": "galiaf-core-api",
      "description": "Resource server audience for core-api",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false
    },
    {
      "clientId": "galiaf-chat-service",
      "name": "galiaf-chat-service",
      "description": "Resource server audience for chat-service",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false
    },
    {
      "clientId": "galiaf-admin-portal",
      "name": "galiaf-admin-portal",
      "description": "Web login for platform admin cabinet",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "https://admin.socvid.ru/auth/callback",
        "http://localhost:3001/auth/callback"
      ],
      "webOrigins": [
        "https://admin.socvid.ru",
        "http://localhost:3001"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "+"
      },
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "email",
        "roles",
        "galiaf-core-api-audience",
        "galiaf-tenant-context"
      ]
    },
    {
      "clientId": "galiaf-manager-cabinet",
      "name": "galiaf-manager-cabinet",
      "description": "Web login for company manager cabinet",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "https://manager.socvid.ru/auth/callback",
        "http://localhost:3002/auth/callback"
      ],
      "webOrigins": [
        "https://manager.socvid.ru",
        "http://localhost:3002"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "+"
      },
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "email",
        "roles",
        "galiaf-core-api-audience",
        "galiaf-tenant-context"
      ]
    },
    {
      "clientId": "galiaf-employee-cabinet",
      "name": "galiaf-employee-cabinet",
      "description": "Web login for employee cabinet",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "https://employee.socvid.ru/auth/callback",
        "http://localhost:3003/auth/callback"
      ],
      "webOrigins": [
        "https://employee.socvid.ru",
        "http://localhost:3003"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "+"
      },
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "email",
        "roles",
        "galiaf-core-api-audience",
        "galiaf-tenant-context"
      ]
    },
    {
      "clientId": "galiaf-mobile-app",
      "name": "galiaf-mobile-app",
      "description": "Expo mobile app login",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "galiaf://auth/callback"
      ],
      "webOrigins": [],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "profile",
        "email",
        "roles",
        "galiaf-core-api-audience",
        "galiaf-tenant-context"
      ]
    }
  ]
}
