KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.6.0
KEYCLOAK_PORT=8080
KEYCLOAK_HEALTH_ENABLED=true
KEYCLOAK_METRICS_ENABLED=true
KEYCLOAK_HTTP_MANAGEMENT_HEALTH_ENABLED=true
KEYCLOAK_PROXY_HEADERS=xforwarded
KEYCLOAK_HOSTNAME=https://auth.socvid.ru
KEYCLOAK_HTTP_ENABLED=true
KEYCLOAK_BOOTSTRAP_ADMIN_USERNAME=admin
KEYCLOAK_BOOTSTRAP_ADMIN_PASSWORD=change-me

KEYCLOAK_DB=postgres
KEYCLOAK_DB_URL=jdbc:postgresql://postgres:5432/keycloak
KEYCLOAK_DB_USERNAME=keycloak
KEYCLOAK_DB_PASSWORD=change-me

KEYCLOAK_IMPORT_REALM=true
